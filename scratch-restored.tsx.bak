                    {canGoPrev && <span className="text-[11px] font-semibold">Episode {epNum - 1}</span>}
                  </button>

                  <button

              <div
                className={`absolute inset-0 z-[10] transition-opacity duration-200 ${showControls ? 'opacity-100' : 'opacity-0 pointer-events-none'} pointer-events-none`}
              >
                <div className="absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-black/70 to-transparent pointer-events-none" />

                {/* Center row: prev ep / -10s / play-pause / +10s / next ep */}
                <div className="absolute inset-0 flex items-center justify-center gap-4 md:gap-8 px-4 pointer-events-none">
                  <button
                    onClick={e => { e.stopPropagation(); goToEpisode(prevHref) }}
                    disabled={!canGoPrev}
                    aria-label="Episode sebelumnya"
                    className="flex flex-col items-center gap-1 text-white disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer pointer-events-auto"
                  >
                    <SkipBack className="w-7 h-7 md:w-8 md:h-8" fill="currentColor" aria-hidden="true" />
                    {canGoPrev && <span className="text-[11px] font-semibold">Episode {epNum - 1}</span>}
                  </button>

                  <button
                    onClick={e => { e.stopPropagation(); skipBy(-SKIP_SECONDS) }}
                    aria-label={`Mundur ${SKIP_SECONDS} detik`}
                    className="relative flex items-center justify-center text-white cursor-pointer pointer-events-auto"
                  >
                    <RotateCcw className="w-9 h-9 md:w-10 md:h-10" aria-hidden="true" />
                    <span className="absolute text-[10px] font-bold mt-0.5">{SKIP_SECONDS}</span>
                  </button>

                  <button
                    onClick={e => { e.stopPropagation(); togglePlayPause() }}
