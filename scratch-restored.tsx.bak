                            {q}p
                            {isBest && (
                              <span className="w-1.5 h-1.5 rounded-full bg-teal-400" aria-label="Terbaik" />
                            )}
                          </span>
                          {quality === q && <Check className="w-3.5 h-3.5 text-emerald-400" aria-hidden="true" />}
                        </button>
                      )
                    })}
