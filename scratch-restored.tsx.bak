                      ? <Pause className="w-8 h-8 md:w-9 md:h-9" fill="currentColor" aria-hidden="true" />
                      : <Play className="w-8 h-8 md:w-9 md:h-9 ml-1" fill="currentColor" aria-hidden="true" />}
                  </button>

                  <button
                    onClick={e => { e.stopPropagation(); skipBy(SKIP_SECONDS) }}
                    aria-label={`Maju ${SKIP_SECONDS} detik`}
                    className="relative flex items-center justify-center text-white cursor-pointer pointer-events-auto"
                  >
                    <RotateCw className="w-9 h-9 md:w-10 md:h-10" aria-hidden="true" />
                    <span className="absolute text-[10px] font-bold mt-0.5">{SKIP_SECONDS}</span>
                  </button>

                  <button
                    onClick={e => { e.stopPropagation(); goToEpisode(nextHref) }}
                    disabled={!canGoNext}
                    aria-label="Episode selanjutnya"
                    className="flex flex-col items-center gap-1 text-white disabled:opacity-30 disabled:cursor-not-allowed cursor-pointer pointer-events-auto"
                  >
                    <SkipForward className="w-7 h-7 md:w-8 md:h-8" fill="currentColor" aria-hidden="true" />
                    {canGoNext && <span className="text-[11px] font-semibold">Episode {epNum + 1}</span>}
