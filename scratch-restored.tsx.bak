// MISSING LINE 1147
// MISSING LINE 1148
// MISSING LINE 1149
// MISSING LINE 1150
// MISSING LINE 1151
// MISSING LINE 1152
// MISSING LINE 1153
// MISSING LINE 1154
// MISSING LINE 1155
// MISSING LINE 1156
// MISSING LINE 1157
// MISSING LINE 1158
// MISSING LINE 1159
// MISSING LINE 1160
// MISSING LINE 1161
// MISSING LINE 1162
// MISSING LINE 1163
// MISSING LINE 1164
// MISSING LINE 1165
// MISSING LINE 1166
// MISSING LINE 1167
// MISSING LINE 1168
// MISSING LINE 1169
// MISSING LINE 1170
// MISSING LINE 1171
// MISSING LINE 1172
// MISSING LINE 1173
// MISSING LINE 1174
// MISSING LINE 1175
// MISSING LINE 1176
// MISSING LINE 1177
// MISSING LINE 1178
// MISSING LINE 1179
              // ngatur buffering di sekitar timestamp target SEBELUM playback
              // mulai, jauh lebih reliable buat sumber m3u8 kayak Otakudesu/
              // Sokuja/NontonAnimeID kita.
              startPosition: resumeAt > 0 ? resumeAt : -1,
            })
            hls.loadSource(proxiedUrl)
            hls.attachMedia(videoEl)

            // Kunci ke level bitrate tertinggi yang ada di manifest ini &
            // matiin ABR — jadi gak diam-diam turun kualitas pas koneksi
            // lemot. Mirror Indo kita rata-rata cuma 1 level per "quality"
            // (jadi ini biasanya no-op), tapi kalau ternyata manifest-nya
            // multi-bitrate, ini yang nge-lock ke yang paling tinggi.
            hls.on(Hls.Events.MANIFEST_PARSED, () => {
              if (!hls.levels || hls.levels.length === 0) return
              let bestIdx = 0
              let bestHeight = 0
              hls.levels.forEach((lvl: { height?: number }, idx: number) => {
                const h = lvl.height ?? 0
                if (h >= bestHeight) { bestHeight = h; bestIdx = idx }
              })
              hls.currentLevel = bestIdx // angka selain -1 = matiin auto/ABR
            })

            // PENTING: hls.js gak otomatis nge-forward error internalnya ke
            // event 'error' bawaan <video>, jadi tanpa listener ini, manifest
            // yang gagal di-load (404 dari proxy, CORS, m3u8 corrupt, dll)
            // bakal diem aja — onError di <video> gak pernah kepanggil,
            // onLoadedData juga gak pernah kepanggil, dan loading overlay
            // nyangkut selamanya. Fatal error di sini di-treat sama kayak
            // native video error: reset & coba resolve ulang.
            hls.on(Hls.Events.ERROR, (_event: unknown, data: { fatal?: boolean }) => {
              if (!data?.fatal || cancelled) return
              hls.destroy()
              if (hlsRef.current === hls) hlsRef.current = null
              handleDirectVideoError()
            })

            hlsRef.current = hls
            return
          }
        } catch { }
      }

      // Jalur native (bukan hls.js — file progresif biasa, atau Safari yang
      // punya native HLS support sendiri). Di sini currentTime manual abis
      // 'loadedmetadata' (lewat JSX onLoadedMetadata → seekToResume) memang
      // cara yang benar, karena browser yang atur buffering-nya sendiri.
      // Taruh lagi ke ref di sini (bukan cuma andelin fallback loadPosition
      // di seekToResume) khusus buat kasus override ganti-kualitas, biar
      // resume ke currentTime yang lagi jalan, bukan localStorage yang lebih
      // lama.
      if (resumeAt > 0) resumeSecondsRef.current = resumeAt
      videoEl.src = proxiedUrl
    }

    setupVideo()

    return () => {
      cancelled = true
      if (hlsRef.current) { hlsRef.current.destroy(); hlsRef.current = null }
    }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [directUrl, server])

  function handleDirectVideoError() {
    setDirectUrl(null)
    // Source yang lagi aktif gak punya iframe fallback (kasus umum buat
    // NontonAnimeID) — daripada nampilin iframe kosong, coba resolve ulang.
    if (!indoSrc) fetchIndoSrc()
  }

  // ── Prefetch hls.js begitu server 'indo' dipilih, bukan pas directUrl udah
  // ada — sebelumnya chunk hls.js baru mulai di-download SETELAH source
  // ketemu, nambah 1 round-trip lagi di atas waktu tunggu yang udah ada.
  // Sekarang download-nya numpang jalan bareng proses resolve source, jadi
  // pas directUrl datang, hls.js kemungkinan besar udah siap di cache browser. ──
  useEffect(() => {
    if (server === 'indo') { import('hls.js').catch(() => { /* silent, fallback native/proxiedUrl tetap jalan */ }) }
  }, [server])

  useEffect(() => {
    if (server === 'indo' && infoReady) fetchIndoSrc()
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [server, malId, epNum, infoReady, quality])

  function handleIframeLoad() {
    // currentSrc (= indoSrc, URL iframe) bisa null walau stream-nya valid —
    // kejadian kalau source balikin directUrl tanpa iframe fallback sama
    // sekali (Sokuja, confirmed 29 Jun 2026). Guard ini dulu cuma ngecek
    // currentSrc, jadi loading overlay nyangkut selamanya buat source kayak
    // gitu walau <video>-nya udah beneran play.
    if (!currentSrc && !directUrl) return
    setIsLoading(false)
    save(Math.max(5, progressRef.current))
    startTracking()
  }

  function switchServer(s: Server) {
    if (s === server) return
    stopTracking()
    try { localStorage.setItem('preferred-server', s) } catch { /* silent */ }
    if (s !== 'indo') {
      setIndoSrc(null)
      setDirectUrl(null)
      setIndoError(null)
      setIndoSource('otakudesu')
      setIndoReferer(null)
      setIframeKey(k => k + 1)
    }
    setServer(s)
  }

  // ── Jalur Otakudesu — logikanya sama persis kayak sebelumnya, cuma
  // dibungkus jadi fungsi sendiri (return hasil, gak langsung setState di
  // tengah jalan) supaya bisa ditembak BARENGAN sama multi-source lewat
  // Promise.all, bukan gantian nunggu ini gagal dulu baru nyoba yang lain. ──
  async function runOtakudesuLookup(manualQuery: string | undefined, isStale: () => boolean) {
    let iframe: string | null = null
    let direct: string | null = null
    let qualities: number[] = []
    let ok = false
    let epTitle: string | null = null
    let notice: string | null = null
    let title = manualQuery || (animeInfoRef.current.title !== 'Unknown' ? animeInfoRef.current.title : '')

    if (!manualQuery && indoMalIdRef.current === malId && indoEpisodesRef.current.length > 0) {
      let epData = indoEpisodesRef.current.find(e => e.episode === epNum)

      if (!epData?.url) {
        const candidates = indoEpisodesRef.current.filter(e => e.url)
        if (candidates.length > 0) {
          epData = candidates.reduce((closest, e) =>
            Math.abs(e.episode - epNum) < Math.abs(closest.episode - epNum) ? e : closest
          )
          notice = `Episode ${epNum} ga ada di Otakudesu — nampilin episode terdekat: Ep ${epData.episode}`
        }
      }

      if (epData?.url) {
        for (let attempt = 0; attempt < 2 && !iframe; attempt++) {
          if (attempt > 0) await new Promise(r => setTimeout(r, 600))
          const streamRes = await fetch(`/api/proxy/stream-indo?endpoint=stream&url=${encodeURIComponent(epData.url)}&quality=${quality}`)
          const streamJson = await streamRes.json()
          iframe = streamJson.data?.iframe ?? null
          direct = streamJson.data?.directUrl ?? null
          qualities = streamJson.data?.availableQualities ?? []
          if (isStale()) return { iframe, direct, qualities, ok, epTitle, notice, title }
        }
        if (iframe) { epTitle = epData.title ?? null; ok = true }
      }
    } else {
      const searchParams = new URLSearchParams({ endpoint: 'auto', episode: String(epNum), quality: String(quality) })
      if (manualQuery) {
        searchParams.set('title', manualQuery)
      } else {
        searchParams.set('malId', malId)
        if (animeInfoRef.current.title && animeInfoRef.current.title !== 'Unknown') {
          searchParams.set('title', animeInfoRef.current.title)
        }
      }
      const altTitles = animeInfoRef.current.altTitles
      if (altTitles && altTitles.length > 0) searchParams.set('altTitles', altTitles.join(','))

      let json: any = null
      let searchFailed = false
      for (let attempt = 0; attempt < 2 && !iframe; attempt++) {
        if (attempt > 0) await new Promise(r => setTimeout(r, 600))
        const res = await fetch(`/api/proxy/stream-indo?${searchParams}`)
        json = await res.json()
        if (isStale()) return { iframe, direct, qualities, ok, epTitle, notice, title }
        if (!res.ok || json.error) { searchFailed = true; break }
        iframe = json.data?.currentEpisode?.iframe ?? null
        direct = json.data?.currentEpisode?.directUrl ?? null
        qualities = json.data?.currentEpisode?.availableQualities ?? []
      }

      if (!searchFailed && json?.data) {
        indoEpisodesRef.current = json.data?.episodes ?? []
        indoMalIdRef.current = malId
        title = json.data?.anime?.title || title

        const meta = json.data?.meta
        if (meta && meta.isExactMatch === false) {
          notice = `Episode ${meta.episodeRequested} ga ada di Otakudesu — nampilin episode terdekat: Ep ${meta.episodeFound}`
        }
        if (iframe) { epTitle = json.data?.currentEpisode?.title ?? null; ok = true }
      }
    }

    return { iframe, direct, qualities, ok, epTitle, notice, title }
  }

  // ── Jalur multi-source. Sekarang ditembak BARENGAN sama Otakudesu (pakai
  // title yang udah kita punya dari animeInfoRef), bukan nunggu Otakudesu
  // gagal/kurang bagus dulu baru mulai. Trade-off-nya: 1 request scrape
  // ekstra ke server yang kadang kebuang (kalau ternyata Otakudesu-nya udah
  // cukup bagus) — tapi motong waktu tunggu total, karena dua source resolve
  // paralel, bukan gantian. ──
  async function runMultiSourceLookup(title: string, episodeNum: number = epNum, q: number = quality) {
    if (!title) return null
    try {
      const msParams = new URLSearchParams({ title, episode: String(episodeNum), quality: String(q) })
      const msRes = await fetch(`/api/proxy/stream-indo?endpoint=multi-stream&${msParams}`)
      const msJson = await msRes.json()
      if (msJson.error || (!msJson.data?.directUrl && !msJson.data?.iframe)) return null
      return {
        iframe: (msJson.data.iframe ?? null) as string | null,
        direct: (msJson.data.directUrl ?? null) as string | null,
        qualities: (msJson.data.availableQualities ?? []) as number[],
        source: (msJson.data.source ?? 'otakudesu') as string,
        referer: (msJson.data.episodeUrl ?? null) as string | null,
      }
    } catch {
      return null
    }
  }

  async function fetchIndoSrc(manualQuery?: string) {
    const mySeq = ++indoFetchSeqRef.current
    const isStale = () => mySeq !== indoFetchSeqRef.current

    // ── Cache hit: skip network sama sekali ──
    const cKey = indoCacheKey(malId, epNum, quality, manualQuery)
    const cached = indoResultCacheRef.current.get(cKey)
    if (cached) {
      setIndoLoading(false)
      setIndoError(null)
      setIndoNotice(cached.notice)
      if (cached.epTitle) setIndoEpTitle(cached.epTitle)
      setIndoSource(cached.source)
      setIndoReferer(cached.referer)
      setDirectUrl(cached.direct)
      setIndoSrc(cached.iframe)
      setAvailableQualities(cached.qualities)
      prefetchNextEpisode()
      return
    }

    setIndoLoading(true)
    setIndoError(null)
    setIndoNotice(null)
    setIndoSrc(null)
    setDirectUrl(null)
    setAvailableQualities([])
    setIndoSource('otakudesu')
    setIndoReferer(null)

    const titleGuess = manualQuery || (animeInfoRef.current.title !== 'Unknown' ? animeInfoRef.current.title : '')

    try {
      // ── Race paralel: kedua promise ini mulai jalan di sini juga, BUKAN
      // gantian. multiSourcePromise cuma nunggu kalau kepake nanti. ──
      const otakudesuPromise = runOtakudesuLookup(manualQuery, isStale)
      const multiSourcePromise = titleGuess ? runMultiSourceLookup(titleGuess) : Promise.resolve(null)

      const otaku = await otakudesuPromise
      if (isStale()) return
      if (otaku.notice) setIndoNotice(otaku.notice)
      if (otaku.ok) setIndoEpTitle(otaku.epTitle)

      let iframe = otaku.iframe
      let direct = otaku.direct
      let qualities = otaku.qualities
      let source = 'otakudesu'
      let referer: string | null = null

      // Threshold-nya ngikutin `quality` yang dipilih user (bukan hardcoded
      // 720p) — kalau user pilih 1080p tapi Otakudesu cuma punya 720p, source
      // lain tetap ikut dipertimbangkan walau Otakudesu "berhasil".
      const otakudesuBest = qualities.length > 0 ? Math.max(...qualities) : 0
// MISSING LINE 1451
